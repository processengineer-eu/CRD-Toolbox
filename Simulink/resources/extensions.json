        "action": "#myCustomMenus.doPlotLiquidHeatCapacity"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemLiquid4",
        "text": "Liquid Heat Conductivity",
        "action": "#myCustomMenus.doPlotLiquidConductivity"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemLiquid5",
