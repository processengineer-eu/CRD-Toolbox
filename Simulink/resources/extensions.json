        "action": "#myCustomMenus.doPlotLiquidViscosity"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemLiquid6",
        "text": "Liquid Molar Volume",
        "action": "#myCustomMenus.doPlotLiquidMolarVolume"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemLiquid7",
        "text": "Liquid Heat of Vaporization",
        "action": "#myCustomMenus.doPlotLiquidHeatOfVaporization"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemLiquid8",
        "text": "Liquid Vapor Pressure",
        "action": "#myCustomMenus.doPlotLiquidVaporPressure"
      }
    ]
  },

  "myCustomMenus.doPlotLiquidEnthalpy": {
    "type": "Action",
    "name": "myCustomMenus.doPlotLiquidEnthalpy",
    "text": "Enthalpy",
    "description": "plot Liquid Enthalpy for all species",
    "callback": "plotLiquidEnthalpy"
  },

  "myCustomMenus.doPlotLiquidEnergy":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotLiquidEnergy",
    "text": "Gibbs Energy",
    "description": "plot Liquid Energy for all species",
    "callback": "plotLiquidEnergy"  
  },

  "myCustomMenus.doPlotLiquidHeatCapacity":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotLiquidHeatCapacity",
    "text": "Heat Capacity",
    "description": "plot Liquid Heat Capacity for all species",
    "callback": "plotLiquidHeatCapacity"
  },

  "myCustomMenus.doPlotLiquidConductivity":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotLiquidConductivity",
    "text": "Heat Conductivity",
    "description": "plot Liquid Heat Conductivity",
    "callback": "plotLiquidHeatConductivity"
  },

  "myCustomMenus.doPlotLiquidViscosity":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotLiquidViscosity",
    "text": "Viscosity",
    "description": "plot Liquid Viscosity",
    "callback": "plotLiquidViscosity"
  },

  "myCustomMenus.doPlotLiquidMolarVolume":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotLiquidMolarVolume",
    "text": "Molar Volume",
    "description": "plot Liquid Molar Volume",
    "callback": "plotLiquidMolarVolume"
  },

  "myCustomMenus.doPlotLiquidHeatOfVaporization":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotLiquidHeatOfVaporization",
    "text": "Heat of Vaporization",
    "description": "plot Liquid Heat of Vaporization",
    "callback": "plotLiquidHeatOfVaporization"
  },
  "myCustomMenus.doPlotLiquidVaporPressure":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotLiquidVaporPressure",
    "text": "Vapor Pressure",
    "description": "plot Liquid Vapor Pressure",
    "callback": "plotLiquidVaporPressure"
  },

