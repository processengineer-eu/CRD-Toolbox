      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemLiquid1",
        "text": "Liquid Enthalpy",
        "action": "#myCustomMenus.doPlotLiquidEnthalpy"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemLiquid2",
