{
  "mw.schemaVersion": "1.0.0",

  "mw.simulink.editor.contextMenu.focusMenu:after": [
    "#myCustomMenus.myMenuSectionWrapperGas",
    "#myCustomMenus.myMenuSectionWrapperLiquid",
    "#myCustomMenus.myMenuSectionWrapperSolid"
  ],

  "myCustomMenus.myMenuSectionWrapperGas": {
    "type": "MenuSection",
    "name": "myCustomMenus.myMenuSectionWrapperGas",
    "when": "selection.Name == 'Properties Gas'",
    "items": [
      {
        "type": "DropDownItem",
        "name": "myCustomMenus.myMainMenuGas",
        "popup": "#myCustomMenus.myMenuGas",
        "textOverride": "Plot"
      }
    ]
  },

  "myCustomMenus.myMenuGas": {
    "type": "Menu",
    "name": "myCustomMenus.myMenuGas",
    "sections": [
      "#myCustomMenus.myMenuSectionGas"
    ]
  },

  "myCustomMenus.myMenuSectionGas": {
    "type": "MenuSection",
    "name": "myCustomMenus.myMenuSectionGas",
    "visible": true,
    "text": "Plot Properties",
    "items": [
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemGas1",
        "text": "Gas Enthalpy",
        "action": "#myCustomMenus.doPlotGasEnthalpy"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemGas2",
        "text": "Gas Energy",
        "action": "#myCustomMenus.doPlotGasEnergy"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemGas3",
        "text": "Gas Heat Capacity",
        "action": "#myCustomMenus.doPlotGasHeatCapacity"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemGas4",
        "text": "Gas Heat Conductivity",
        "action": "#myCustomMenus.doPlotGasConductivity"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemGas5",
        "text": "Gas Heat Viscosity",
        "action": "#myCustomMenus.doPlotGasViscosity"
      }
    ]
  },

  "myCustomMenus.doPlotGasEnthalpy": {
    "type": "Action",
    "name": "myCustomMenus.doPlotGasEnthalpy",
    "text": "Enthalpy",
    "description": "plot Gas Enthalpy for all species",
    "callback": "plotGasEnthalpy"
  },

  "myCustomMenus.doPlotGasEnergy":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotGasEnergy",
    "text": "Gibbs Energy",
    "description": "plot Gas Energy for all species",
    "callback": "plotGasEnergy"  
  },

  "myCustomMenus.doPlotGasHeatCapacity":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotGasHeatCapacity",
    "text": "Heat Capacity",
    "description": "plot Gas Heat Capacity for all species",
    "callback": "plotGasHeatCapacity"
  },

  "myCustomMenus.doPlotGasConductivity":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotGasConductivity",
    "text": "Heat Conductivity",
    "description": "plot Gas Heat Conductivity",
    "callback": "plotGasHeatConductivity"
  },

  "myCustomMenus.doPlotGasViscosity":
  {
    "type": "Action",
    "name": "myCustomMenus.doPlotGasViscosity",
    "text": "Viscosity",
    "description": "plot Gas Viscosity",
    "callback": "plotGasViscosity"
  },

  "myCustomMenus.myMenuSectionWrapperLiquid": {
    "type": "MenuSection",
    "name": "myCustomMenus.myMenuSectionWrapperLiquid",
    "when": "selection.Name == 'Properties Liquid'",
