        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemSolid1",
        "text": "Solid Enthalpy",
        "action": "#myCustomMenus.doPlotSolidEnthalpy"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemSolid2",
        "text": "Solid Energy",
        "action": "#myCustomMenus.doPlotSolidEnergy"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemSolid3",
        "text": "Solid Heat Capacity",
        "action": "#myCustomMenus.doPlotSolidHeatCapacity"
      },
      {
        "type": "MenuItem",
        "name": "myCustomMenus.myMenuItemSolid4",
